# ============================================================================
#  Vinylarium — environment configuration
#  Copy this file to `.env` and adjust the values before `docker compose up`.
# ============================================================================

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=vinylarium
POSTGRES_PASSWORD=change_me_please
POSTGRES_DB=vinylarium
# DATABASE_URL is built from the values above; keep host = db (the compose service)
DATABASE_URL=postgresql://vinylarium:change_me_please@db:5432/vinylarium?schema=public

# ── Redis (cache + job queue) ───────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Authentication ──────────────────────────────────────────────────────────
# Generate a long random string, e.g.  openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=30d

# ── Discogs (required for import & enrichment) ──────────────────────────────
# Authenticate one of two ways (either unlocks 60 req/min + cover images):
#  1) Personal access token: https://www.discogs.com/settings/developers
DISCOGS_TOKEN=
#  2) App Consumer key + secret (create an app in the same settings page)
DISCOGS_CONSUMER_KEY=
DISCOGS_CONSUMER_SECRET=
# Discogs requires a descriptive User-Agent identifying your app
DISCOGS_USER_AGENT=Vinylarium/0.1 +https://github.com/Nyx-Off/Vinylarium

# ── MusicBrainz (optional, future enrichment) ───────────────────────────────
MUSICBRAINZ_USER_AGENT=Vinylarium/0.1 ( https://github.com/Nyx-Off/Vinylarium )

# ── Genius (optional) — enables automatic lyrics fetching during enrichment ──
# Create a token at https://genius.com/api-clients (Client Access Token).
GENIUS_ACCESS_TOKEN=
# Target language for the Genius album descriptions ("anecdotes"); they are
# machine-translated from English. Leave empty to keep the original English.
ANECDOTE_LANG=fr

# ── App ─────────────────────────────────────────────────────────────────────
# Host port the web UI is exposed on
FRONTEND_PORT=8080
NODE_ENV=production
